# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.coverage

# Virtual environments
.venv/
venv/

# Environment / secrets — the API reads several OPENMED_STUDIO_* env vars (see the
# README "Authentication & PHI safety" section and openmed_studio/ for the full set)
.env
.env.*

# Note: uv.lock is intentionally committed — this is an application-style
# project, so the lockfile is tracked for reproducible `uv sync`.

# Local model / data caches (OpenMed defaults to ~/.cache/openmed, but ignore
# any project-local copies too)
.cache/
models/
*.safetensors
*.npz

# Streamlit local secrets (e.g. the UI's X-API-Key) — never commit
.streamlit/secrets.toml
