# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.coverage

# Virtual environments
.venv/
venv/

# Environment / secrets (the API reads OPENMED_STUDIO_API_KEY / OPENMED_STUDIO_BACKEND / OPENMED_STUDIO_HOST / OPENMED_STUDIO_PORT)
.env
.env.*

# Note: uv.lock is intentionally committed — this is an application-style
# project, so the lockfile is tracked for reproducible `uv sync`.

# Local model / data caches (OpenMed defaults to ~/.cache/openmed, but ignore
# any project-local copies too)
.cache/
models/
*.safetensors
*.npz
