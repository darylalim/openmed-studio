# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.ty_cache/
.coverage

# Virtual environments
.venv/
venv/

# Environment / secrets — the app reads OPENMED_STUDIO_BACKEND and
# OPENMED_STUDIO_MAX_TEXT_LENGTH (see the README); keep any local .env out of git
.env
.env.*

# Note: uv.lock is intentionally committed — this is an application-style
# project, so the lockfile is tracked for reproducible `uv sync`.

# Local model / data caches — OpenMed caches the PII model plus each per-domain
# NER model under ~/.cache/openmed; also ignore any project-local copies
.cache/
models/
*.safetensors
*.npz

# App download outputs — de-identified / anonymized / re-identified text may carry PHI or
# its surrogates; never commit one if a browser saves it into the repo
/deidentified.txt
/deidentified_batch.json
/anonymized.txt
/reidentified.txt

# Streamlit local secrets — never commit (.streamlit/config.toml is tracked; secrets are not)
.streamlit/secrets.toml

# Claude Code local + runtime files (a shared .claude/settings.json may still be committed)
.claude/settings.local.json
.claude/scheduled_tasks.lock
